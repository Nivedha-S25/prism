# Copy to `.env` and fill in. Never commit the real .env.

# --- LLM (Module 1 behavioral scoring) ---
# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Whisper (Module 1 speech-to-text) ---
# One of: tiny, base, small, medium, large
WHISPER_MODEL=base

# --- Personality model (Module 2) ---
PERSONALITY_MODEL_NAME=bert-base-uncased
PERSONALITY_CHECKPOINT=

# --- API security ---
# Comma-separated list of accepted bearer API keys for the REST API.
PRISM_API_KEYS=dev-local-key

# --- Misc ---
PRISM_DEVICE=cpu          # cpu | cuda
PRISM_LOG_LEVEL=INFO
